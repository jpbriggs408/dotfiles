# ----- 1.7 Gist -----
# All gists are forced private by the gist() wrapper below.
# Uses gist CLI (supports OpenGist and GitHub backends)
#
# Aliases:
#   gist-pipe          Pipe stdin to a private gist with diff syntax highlighting
#   gist-wip           Gist your unstaged working tree changes
#   gist-branch        Gist all changes vs origin/main (staged + unstaged)
#   gist-since-main    Gist only committed changes since branch diverged from main
#
# Stdout helpers (no gist, just print):
#   diff-main          Print committed diff since branch point
#   diff-branch        Print all changes vs origin/main

# Wrapper: inject -p (private) on every gist call, block --no-private
gist() {
    if [[ " $* " == *" --no-private "* ]]; then
        echo "Public gists are blocked. All gists must be private."
        return 1
    fi
    command gist -p "$@"
}

diff-main() { git diff $(git merge-base HEAD main) HEAD; }
diff-branch() { git diff origin/main; }

alias gist-pipe='gist -t diff'
alias gist-wip='git diff | gist-pipe'
alias gist-branch='diff-branch | gist-pipe'
alias gist-since-main='diff-main | gist-pipe'

