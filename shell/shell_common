# Homebrew -- multi-platform: linuxbrew on VMs, /opt/homebrew on macOS
if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [[ -d "$HOME/.linuxbrew" ]]; then
    eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
elif [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif ! command -v brew &> /dev/null; then
    echo "Homebrew not found. Install: https://brew.sh"
fi

# Auto-update Claude Code on shell startup (silent, non-blocking)
if command -v brew &> /dev/null; then
    (brew upgrade --cask claude-code &>/dev/null &)
fi


