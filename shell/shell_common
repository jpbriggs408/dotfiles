# ----- 2.1 File Operations -----

# extract <file> -- auto-detect archive type and extract
function extract() {
    if [ -f $1 ] ; then
        case $1 in
            *.tar.bz2)   tar xvjf $1     ;;
            *.tar.gz)    tar xvzf $1     ;;
            *.bz2)       bunzip2 $1      ;;
            *.rar)       unrar x $1      ;;
            *.gz)        gunzip $1       ;;
            *.tar)       tar xvf $1      ;;
            *.tbz2)      tar xvjf $1     ;;
            *.tgz)       tar xvzf $1     ;;
            *.zip)       unzip $1        ;;
            *.Z)         uncompress $1   ;;
            *.7z)        7z x $1         ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file!"
    fi
}

# extract_dir [dir] [output] [excludes] [max_files_per_part]
# Snapshot a directory's structure and file contents into markdown parts.
# Useful for feeding codebases to LLMs or documentation.
#   dir       Target directory (default: .)
#   output    Output directory (default: codebase_snapshot)
#   excludes  Comma-separated dirs to skip (default: node_modules,vendor,dist,build,.git)
#   max       Files per part file (default: 50)
function extract_dir() {
  local TARGET_DIR="${1:-.}"
  local OUTPUT_DIR="${2:-codebase_snapshot}"
  local EXCLUDE_PATTERNS="${3:-node_modules,vendor,dist,build,.git}"
  local MAX_FILES_PER_PART="${4:-50}"

  mkdir -p "$OUTPUT_DIR"

  local EXCLUDE_ARGS=""
  IFS=',' read -ra EXCLUSIONS <<< "$EXCLUDE_PATTERNS"
  for pattern in "${EXCLUSIONS[@]}"; do
    EXCLUDE_ARGS="$EXCLUDE_ARGS -not -path \"*/$pattern/*\""
  done

  echo "Analyzing directory structure of $TARGET_DIR..."

  local TOTAL_FILES=$(eval "find \"$TARGET_DIR\" -type f $EXCLUDE_ARGS | wc -l")
  echo "Found $TOTAL_FILES files to process"

  local INDEX_FILE="$OUTPUT_DIR/00_index.md"
  {
    echo "# Codebase Snapshot: $(basename "$(realpath "$TARGET_DIR")")"
    echo "Generated on $(date '+%Y-%m-%d %H:%M:%S')"
    echo
    echo "## Directory Structure"
    echo '```'
    if command -v tree &> /dev/null; then
      eval "tree -I \"$(echo "$EXCLUDE_PATTERNS" | tr ',' '|')\" \"$TARGET_DIR\""
    else
      eval "find \"$TARGET_DIR\" -type d -not -path \"*/\.*\" $EXCLUDE_ARGS | sort | sed -e 's/[^-][^\/]*\//  |   /g' -e 's/|\([^ ]\)/|-- \1/'"
    fi
    echo '```'
    echo
    echo "## File Index"
    echo "The codebase snapshot is split into multiple parts:"
    echo
  } > "$INDEX_FILE"

  local COUNTER=0
  local PART_COUNTER=1
  local FILE_COUNTER=0
  local PART_FILE="$OUTPUT_DIR/part_$(printf "%02d" $PART_COUNTER).md"

  echo "# Codebase Snapshot: Part $PART_COUNTER" > "$PART_FILE"
  echo "## File Contents" >> "$PART_FILE"
  echo "- [Part $PART_COUNTER](./part_$(printf "%02d" $PART_COUNTER).md)" >> "$INDEX_FILE"

  while IFS= read -r file; do
    if file "$file" | grep -q "binary"; then
      continue
    fi

    COUNTER=$((COUNTER + 1))
    FILE_COUNTER=$((FILE_COUNTER + 1))
    PROGRESS=$((COUNTER * 100 / TOTAL_FILES))
    printf "\rProcessing files: %d/%d (%d%%) - %s" "$COUNTER" "$TOTAL_FILES" "$PROGRESS" "$file" >&2

    local EXT="${file##*.}"

    if [ "$FILE_COUNTER" -gt "$MAX_FILES_PER_PART" ]; then
      PART_COUNTER=$((PART_COUNTER + 1))
      FILE_COUNTER=1
      PART_FILE="$OUTPUT_DIR/part_$(printf "%02d" $PART_COUNTER).md"
      echo "# Codebase Snapshot: Part $PART_COUNTER" > "$PART_FILE"
      echo "## File Contents" >> "$PART_FILE"
      echo "- [Part $PART_COUNTER](./part_$(printf "%02d" $PART_COUNTER).md)" >> "$INDEX_FILE"
    fi

    {
      echo
      echo "### $file"
      echo "\`\`\`$EXT"
      cat "$file"
      echo "\`\`\`"
      echo
    } >> "$PART_FILE"

  done < <(eval "find \"$TARGET_DIR\" -type f $EXCLUDE_ARGS | sort")

  printf "\rProcessing complete: %d/%d (100%%)                         \n" "$TOTAL_FILES" "$TOTAL_FILES" >&2
  echo "Snapshot saved to $OUTPUT_DIR/"
  echo "Index file: $INDEX_FILE"
  echo "Total parts: $PART_COUNTER"
}

# ----- 2.2 Archives -----
function maketar() { tar cvzf "${1%%/}.tar.gz"  "${1%%/}/"; }
function makezip() { zip -r "${1%%/}.zip" "$1" ; }

# ----- 2.3 Permissions -----
# sanitize <dir> -- set sane permissions (owner rw, group r, no other)
function sanitize() { chmod -R u=rwX,g=rX,o= "$@" ;}

# ----- 2.4 Git -----
# apply-patch <url> -- download and apply a git patch from a URL
function apply-patch() {
    curl $1 | git apply -v --index
}

# ----- 2.5 Yarn/JFROG -----
# yarn_prod <packages...> -- install packages from the prod registry
# Uses a clean workspace in ~/development/briggs/prod-npmrc/
function yarn_prod() {
    cd ~/development/briggs/prod-npmrc/
    rm -rf node_modules package.json yarn.lock
    yarnpkg cache clean
    yarnpkg init -y
    yarnpkg add $@
    cd -
}

# ----- 2.6 SSH -----
# setup_ssh_key <host> [key_path] -- set up SSH key auth to a remote host
# Generates a key if needed, copies it, tests the connection, and updates ~/.ssh/config
# Alias: sshr
setup_ssh_key() {
    local remote_host="$1"
    local ssh_key="${2:-$HOME/.ssh/id_rsa.pub}"

    if [ ! -f "$ssh_key" ]; then
        echo "SSH key not found: $ssh_key"
        echo "Generating a new SSH key..."
        ssh-keygen -t rsa -b 4096 -f "${ssh_key%.pub}"
    fi

    echo "Copying SSH key to $remote_host..."
    ssh-copy-id -i "$ssh_key" "$remote_host"

    echo "Testing SSH connection..."
    ssh -o PasswordAuthentication=no "$remote_host" echo "SSH key-based authentication successful!"

    if [ -f ~/.ssh/config ]; then
        if ! grep -q "Host $remote_host" ~/.ssh/config; then
            echo -e "\nHost $remote_host\n    HostName $remote_host\n    User $USER\n    IdentityFile $ssh_key\n    ControlPath ~/.ssh/controlmasters/%r@%h:%p\n    ControlMaster auto\n    ControlPersist 10m" >> ~/.ssh/config
            echo "Updated SSH config for $remote_host"
        fi
    else
        echo -e "Host $remote_host\n    HostName $remote_host\n    User $USER\n    IdentityFile $ssh_key\n    ControlPath ~/.ssh/controlmasters/%r@%h:%p\n    ControlMaster auto\n    ControlPersist 10m" > ~/.ssh/config
        echo "Created SSH config for $remote_host"
    fi
}

alias sshr='setup_ssh_key'

# sshf <host> [command] -- SSH into a host with your shell config forwarded
# Copies ~/.shell_common to the remote host and sources it on login.
# Your aliases, functions, and settings travel with you.
# Falls back to a normal SSH if the copy fails.
#   sshf myserver              -- interactive shell with your config
#   sshf myserver "ls -la"     -- run a command with your config loaded
sshf() {
    local host="$1"
    shift
    if [ -z "$host" ]; then
        echo "Usage: sshf <host> [command]"
        return 1
    fi
    # Copy shell_common to remote (temp file, cleaned up on logout)
    local remote_rc="/tmp/.shell_common.$$"
    scp -q "$HOME/.shell_common" "$host:$remote_rc" 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "Could not copy config to $host, falling back to plain SSH"
        ssh "$host" "$@"
        return
    fi
    if [ $# -eq 0 ]; then
        # Interactive: source config then launch shell, clean up on exit
        ssh -t "$host" "bash --rcfile $remote_rc -i; rm -f $remote_rc"
    else
        # Command: source config, run command, clean up
        ssh "$host" "source $remote_rc; $@; rm -f $remote_rc"
    fi
}

# ----- 2.7 Utility -----
# mkcd <dir> -- create a directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# bak <file> -- create a .bak copy of a file
bak() { cp "$1"{,.bak}; }

# ----- 2.8 Find -----
# ff <pattern> -- find files matching pattern (case-insensitive)
ff() { find . -type f -iname "*$1*" -ls ; }
# fd <pattern> -- find directories matching pattern (case-insensitive)
fd() { find . -type d -iname "*$1*" -ls ; }


