# ----- Dev workspace (tmux + Claude Code) -----

# mux [session] [dir] -- create or attach to a persistent tmux dev workspace
#
# Two windows:
#   1 "shell"  -- general purpose terminal (default: /srv)
#   2 "claude" -- for Claude Code (just type `claude` or `cc` and press Enter)
#
# If the session already exists, just attach and pick up where you left off.
# Sessions survive SSH disconnects -- reconnect and `mux` again to resume.
#
# Usage:
#   mux                  Create/attach "work" session in /srv
#   mux REGX-1234        Create/attach session named after a ticket
#   mux buildavite ~/src Create/attach "buildavite" session in ~/src
#   mux ls               List all active sessions
mux() {
    # List sessions
    if [ "$1" = "ls" ]; then
        tmux list-sessions 2>/dev/null || echo "No active sessions."
        return
    fi

    local session="${1:-work}"
    local workdir="${2:-/srv}"

    # If session exists, just attach
    if tmux has-session -t "$session" 2>/dev/null; then
        if [ -n "$TMUX" ]; then
            tmux switch-client -t "$session"
        else
            tmux attach -t "$session"
        fi
        return
    fi

    # Create new session with two windows
    tmux new-session -d -s "$session" -n "shell" -c "$workdir"
    tmux new-window -t "$session" -n "claude" -c "$workdir"

    # Start on the shell window
    tmux select-window -t "$session:shell"

    # Attach
    if [ -n "$TMUX" ]; then
        tmux switch-client -t "$session"
    else
        tmux attach -t "$session"
    fi
}
